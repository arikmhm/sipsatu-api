# Server
PORT=3000
NODE_ENV=development

# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql://postgres.[PROJECT]:[PASSWORD]@aws-1-[REGION].pooler.supabase.com:6543/postgres

# Supabase
SUPABASE_URL=https://[PROJECT].supabase.co
